# ============================================================
# Canvas LMS
# ============================================================
CANVAS_BASE_URL=https://canvas.univ.edu
CANVAS_CLIENT_ID=your_developer_key_client_id
CANVAS_CLIENT_SECRET=your_developer_key_client_secret
CANVAS_REDIRECT_URI=http://localhost:8000/auth/canvas/callback
# Per-user OAuth2 token encryption key (generate: openssl rand -hex 32)
CANVAS_TOKEN_ENCRYPTION_KEY=change_me_to_a_random_hex_string

# ============================================================
# WeChat iLink Bot API
# ============================================================
ILINK_BASE_URL=https://ilinkai.weixin.qq.com
# Bot token obtained after QR code scan (set at runtime)
ILINK_BOT_TOKEN=
# Channel version reported by the SDK
ILINK_CHANNEL_VERSION=1.0.3

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=canvasbot
POSTGRES_PASSWORD=canvasbot_secret
POSTGRES_DB=canvas_wechat
DATABASE_URL=postgresql+asyncpg://canvasbot:canvasbot_secret@postgres:5432/canvas_wechat
DATABASE_URL_SYNC=postgresql://canvasbot:canvasbot_secret@postgres:5432/canvas_wechat

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================
# AI / LLM
# ============================================================
# Primary
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Fallback
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# Notifications
# ============================================================
# Beijing time quiet hours (0-23)
QUIET_HOURS_START=22
QUIET_HOURS_END=8
# Context token considered stale after N hours
CONTEXT_TOKEN_STALE_HOURS=12
# Max notifications per user per day
MAX_DAILY_NOTIFICATIONS=20
